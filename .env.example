# ============================================================
# Svetka MVP v1 — Environment Variables
# Скопируйте в .env и заполните значениями
# ============================================================

# --- Bot ---
BOT_TOKEN=your_bot_token_here
BOT_WEBHOOK_URL=https://your-backend-domain.koyeb.app/webhook

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Backend API ---
BACKEND_URL=https://your-backend-domain.koyeb.app
API_SECRET_KEY=change-me-to-random-secret-key-256bits

# --- Super Admin Panel ---
ADMIN_TOKEN=your-super-secret-admin-token
NEXT_PUBLIC_API_URL=https://your-backend-domain.koyeb.app

# --- Mini App ---
NEXT_PUBLIC_MINI_APP_API_URL=https://your-backend-domain.koyeb.app

# --- Environment ---
ENVIRONMENT=development
DEBUG=true
